// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  SUB_ADMIN
  CUSTOMER
}

enum VerificationStatus {
  pending
  verified
  rejected
}

enum OrderStatus {
  pending_verification
  confirmed
  processing
  shipped
  delivered
  cancelled
}

model User {
  id          String     @id @default(uuid())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(CUSTOMER)
  permissions String[]   @default([])
  isActive    Boolean    @default(true)
  orders      Order[]
  reviews     Review[]
  wishlist    Wishlist[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  image     String
  text      String    @default("")
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  description String
  price       Float
  costPrice   Float        @default(0)
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  ageGroup    String
  images      Json         // Array of image URLs (JSON array)
  stock       Int
  benefits    String       // Bullet points or description of benefits
  featured    Boolean      @default(false)
  reviews     Review[]
  wishlist    Wishlist[]
  directSales DirectSale[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}


model DeliveryZone {
  id             String         @id @default(uuid())
  name           String         @unique
  deliveryCharge Float
  isActive       Boolean        @default(true)
  areas          DeliveryArea[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model DeliveryArea {
  id        String       @id @default(uuid())
  name      String
  district  String
  zoneId    String
  zone      DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, district])
}

model Order {
  id                  String             @id @default(uuid())
  userId              String?
  user                User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Customer Data
  customerName        String
  phone               String
  email               String?
  
  // Shipping Data
  district            String
  area                String
  fullAddress         String
  
  // Order Data
  items               Json               // JSON array of items (id, title, price, quantity)
  subtotal            Float
  deliveryCharge      Float
  couponCode          String?
  discount            Float              @default(0)
  
  // Payment Data
  paymentOption       String             // "COD" or "FULL_ADVANCE"
  paymentMethod       String             // "bKash" or "Nagad"
  amountPaid          Float
  amountDueOnDelivery Float
  senderNumber        String
  transactionId       String             @unique
  
  // Status & Meta
  verificationStatus  VerificationStatus @default(pending)
  orderStatus         OrderStatus        @default(pending_verification)
  adminNotes          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model AuditLog {
  id          String   @id @default(uuid())
  adminEmail  String
  adminRole   Role
  action      String   // e.g. "VERIFY_PAYMENT", "REJECT_PAYMENT", "UPDATE_STATUS", "CREATE_SUB_ADMIN", "SUSPEND_SUB_ADMIN"
  targetModel String   // "Order"
  targetId    String   // Order ID
  changes     Json     // JSON representation of mutated attributes or audit details
  createdAt   DateTime @default(now())
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Float
  minOrderAmount  Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DirectSale {
  id         String   @id @default(uuid())
  date       DateTime @default(now())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Int
  price      Float
  receivedBy String
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Investment {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  person    String
  amount    Float
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id         String   @id @default(uuid())
  date       DateTime @default(now())
  paidBy     String
  amount     Float
  invoiceUrl String?
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

